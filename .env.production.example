#############################################
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.production and fill in the values
#############################################

#############################################
# Application Settings
#############################################
PROJECT_NAME=Examify API
MODE=production
API_VERSION=1.0.0

#############################################
# Security
#############################################
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_min_32_chars
ENCRYPT_KEY=CHANGE_THIS_TO_BASE64_ENCODED_KEY_32_bytes

#############################################
# CORS Settings
#############################################
# Frontend domain
BACKEND_CORS_ORIGINS=["https://exampapel.com","https://www.exampapel.com"]

#############################################
# PostgreSQL Database (Docker Container)
#############################################
DATABASE_HOST=examify_database
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_NAME=exams_fastapi_db
DATABASE_PORT=5432
DATABASE_CELERY_NAME=celery_schedule_jobs

#############################################
# Redis Cache
#############################################
REDIS_HOST=examify_redis
REDIS_PORT=6379
REDIS_PASSWORD=vM7$yLp6^Xc3&Hs8*Df1?Uw5%Ga0+Nj9=Tr2!Bx7$Vm6^Pk8@Ls3
REDIS_USE_PASSWORD=true
REDIS_DB=0
REDIS_POOL_SIZE=50
REDIS_POOL_TIMEOUT=20
REDIS_SSL=false
REDIS_SSL_CERT_REQS=none
USE_REDIS_TOKEN_BLACKLIST=true
ENABLE_REDIS_CACHE=true

#############################################
# Admin User
#############################################
FIRST_SUPERUSER_EMAIL=admin@exampapel.com
FIRST_SUPERUSER_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

#############################################
# AWS S3 (Optional - for file storage)
#############################################
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=exampapel-production-bucket

#############################################
# Email Configuration
#############################################
MAIL_SMTP_SERVER=mail.exampapel.com
MAIL_SMTP_PORT=465
MAIL_STARTTLS=False
MAIL_SSL_TLS=True
MAIL_USE_CREDENTIALS=True
MAIL_VALIDATE_CERTS=True
MAIL_SMTP_USERNAME=noreply@exampapel.com
MAIL_SMTP_PASSWORD=your_email_password
MAIL_FROM=noreply@exampapel.com
MAIL_FROM_NAME=ExamPapel
SUPPORT_EMAIL=support@exampapel.com
FRONTEND_URL=https://exampapel.com
TEMPLATE_FOLDER=/code/app/templates

#############################################
# OAuth (Optional)
#############################################
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.exampapel.com/api/v1/user/social-auth/google

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://api.exampapel.com/api/v1/user/social-auth/github

#############################################
# Monitoring & Logging (Optional)
#############################################
LOG_LEVEL=INFO
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

#############################################
# Domain Configuration
#############################################
API_DOMAIN=api.exampapel.com
FRONTEND_DOMAIN=exampapel.com
